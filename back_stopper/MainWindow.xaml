<controls:MetroWindow
    x:Class="back_stopper.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:local="clr-namespace:back_stopper"
    mc:Ignorable="d"
    Title="BackStopper"
    WindowStartupLocation="CenterScreen"
    Background="#F3F6FA"
    MinWidth="1300"
    MinHeight="800"
    Width="1600"
    Height="900"
    Loaded="MetroWindow_Loaded"
    Closed="MetroWindow_Closed" WindowState="Maximized">

    <Window.Resources>
        <!-- BUTTON -->
        <Style x:Key="RoundBtn" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="12,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- INFO CARD -->
        <Style x:Key="InfoCard" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <!-- LABEL HEADER -->
        <Style x:Key="LabelHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <Grid Margin="20">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1*" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- ================= LEFT ================= -->
            <Grid Grid.Column="0" Margin="0,0,20,0">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- EMPLOYEE PANEL -->
                <Border Grid.Row="0"
                        x:Name="border_employee"
                        Background="White"
                        CornerRadius="20"
                        Padding="20"
                        Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.15"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Employee Login" FontSize="24" FontWeight="SemiBold" Foreground="#222"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="#F5F7FB" CornerRadius="12" Margin="20,0">
                            <TextBox x:Name="txt_id_employee"
                                     Height="45" FontSize="20" BorderThickness="0"
                                     Background="Transparent" Padding="15,0"
                                     VerticalContentAlignment="Center" Foreground="#333"
                                     KeyDown="txt_id_employee_KeyDown"
                                     controls:TextBoxHelper.Watermark="Enter Employee ID"/>
                        </Border>
                        <TextBlock Grid.Column="2" x:Name="lb_check_emplyee"
                                   Text="None" VerticalAlignment="Center" HorizontalAlignment="Center"
                                   FontSize="22" FontWeight="SemiBold"/>
                    </Grid>
                </Border>

                <!-- MAIN CARD -->
                <Border Grid.Row="1" x:Name="border_main"
                        Background="White" CornerRadius="20" Padding="30" IsEnabled="False">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.15"/>
                    </Border.Effect>
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="BackStopper JSH" FontSize="30" FontWeight="SemiBold"
                                   Foreground="#222" Margin="0,0,0,25" Grid.Column="0"/>
                            <TextBlock x:Name="txt_notify" Text="-" FontSize="25" FontWeight="SemiBold" Margin="0,0,0,25" Grid.Column="1" HorizontalAlignment="Right" Foreground="#FFE82828"/>
                        </Grid>
                        <Grid Margin="0,0,0,30">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="border_txt_po" Background="#F5F7FB" CornerRadius="12" Margin="0,0,15,0">
                                <TextBox x:Name="txt_po"
                                         Height="45" FontSize="16" BorderThickness="0"
                                         Background="Transparent" Padding="15,0"
                                         VerticalContentAlignment="Center" Foreground="#333"
                                         KeyDown="txt_po_KeyDown"
                                         controls:TextBoxHelper.Watermark="Enter PO Product"/>
                            </Border>
                            <Button Grid.Column="1" x:Name="btn_po_restart"
                                    Click="btn_po_restart_Click" Content="Kết thúc và về gốc"
                                    Height="45" FontSize="15" FontWeight="SemiBold"
                                    Cursor="Hand" Foreground="White" Background="#4F46E5" BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>


                        <UniformGrid Columns="4" Rows="2">

                            <Border Background="#F8FAFC" CornerRadius="14" Padding="14" Margin="6">
                                <StackPanel>
                                    <TextBlock Text="🔢" FontSize="16" Margin="0,0,0,4"/>
                                    <TextBlock Text="AUFNR" FontSize="11" Foreground="#777"/>
                                    <TextBlock x:Name="txt_id" FontSize="16" FontWeight="SemiBold" Foreground="#222" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#F8FAFC" CornerRadius="14" Padding="14" Margin="6">
                                <StackPanel>
                                    <TextBlock Text="📦" FontSize="16" Margin="0,0,0,4"/>
                                    <TextBlock Text="PSTX" FontSize="11" Foreground="#777"/>
                                    <TextBlock x:Name="txt_PSTX" Text="..." FontSize="16" FontWeight="SemiBold" Foreground="#222" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#F8FAFC" CornerRadius="14" Padding="14" Margin="6">
                                <StackPanel>
                                    <TextBlock Text="⚖️" FontSize="16" Margin="0,0,0,4"/>
                                    <TextBlock Text="GAMNG" FontSize="11" Foreground="#777"/>
                                    <TextBlock x:Name="txt_gamng" Text="..." FontSize="16" FontWeight="SemiBold" Foreground="#222" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#F8FAFC" CornerRadius="14" Padding="14" Margin="6">
                                <StackPanel>
                                    <TextBlock Text="📏" FontSize="16" Margin="0,0,0,4"/>
                                    <TextBlock Text="L" FontSize="11" Foreground="#777"/>
                                    <TextBlock x:Name="txt_l" Text="..." FontSize="16" FontWeight="SemiBold" Foreground="#222" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#F8FAFC" CornerRadius="14" Padding="14" Margin="6">
                                <StackPanel>
                                    <TextBlock Text="⭕" FontSize="16" Margin="0,0,0,4"/>
                                    <TextBlock Text="D" FontSize="11" Foreground="#777"/>
                                    <TextBlock x:Name="txt_d" Text="..." FontSize="16" FontWeight="SemiBold" Foreground="#222" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#F0FDF4" CornerRadius="14" Padding="14" Margin="6">
                                <StackPanel>
                                    <TextBlock Text="🕳️" FontSize="16" Margin="0,0,0,4"/>
                                    <TextBlock Text="AirHole" FontSize="11" Foreground="#777"/>
                                    <TextBlock x:Name="txt_airhole" Text="..." FontSize="16" FontWeight="SemiBold" Foreground="#16A34A" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#F8FAFC" CornerRadius="14" Padding="14" Margin="6">
                                <StackPanel>
                                    <TextBlock Text="⭕" FontSize="16" Margin="0,0,0,4"/>
                                    <TextBlock Text="D" FontSize="11" Foreground="#777"/>
                                    <TextBlock x:Name="" Text="..." FontSize="16" FontWeight="SemiBold" Foreground="#222" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>


                        </UniformGrid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ================= RIGHT ================= -->
            <Border Grid.Column="1"
                    x:Name="border_control"
                    Background="White"
                    CornerRadius="20"
                    Padding="18"
                    IsEnabled="False">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.15"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Header -->
                        <RowDefinition Height="Auto"/>
                        <!-- Sensors -->
                        <RowDefinition Height="Auto"/>
                        <!-- Servo status -->
                        <RowDefinition Height="Auto"/>
                        <!-- Servo travel -->
                        <RowDefinition Height="*"/>
                        <!-- Log -->
                        <RowDefinition Height="Auto"/>
                        <!-- Buttons + FAB -->
                    </Grid.RowDefinitions>

                    <!-- HEADER -->
                    <Grid Grid.Row="0" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Machine Control" FontSize="20" FontWeight="SemiBold"
                                   Foreground="#222" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- SENSORS -->
                    <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Style="{StaticResource InfoCard}" MinWidth="85">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelHeader}" Text="Sensor Min"/>
                                <TextBlock x:Name="txt_ss1" Text="OFF" FontSize="17" FontWeight="Bold" Foreground="#DC2626"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource InfoCard}" MinWidth="85">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelHeader}" Text="Sensor Max"/>
                                <TextBlock x:Name="txt_ss2" Text="OFF" FontSize="17" FontWeight="Bold" Foreground="#DC2626"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource InfoCard}" MinWidth="85">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelHeader}" Text="Sensor Home"/>
                                <TextBlock x:Name="txt_ss3" Text="OFF" FontSize="17" FontWeight="Bold" Foreground="#DC2626"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <!-- SERVO STATUS -->
                    <Border Grid.Row="2" Style="{StaticResource InfoCard}" Margin="5,0,5,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Servo" Style="{StaticResource LabelHeader}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txt_status_servo" Grid.Column="1"
                                       Text="Please Connect" FontSize="15" FontWeight="Bold" Foreground="#2563EB"/>
                        </Grid>
                    </Border>

                    <!-- SERVO TRAVEL -->
                    <Border Grid.Row="3" Style="{StaticResource InfoCard}" Margin="5,0,5,10">
                        <StackPanel>
                            <TextBlock Text="Servo Travel" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#222" Margin="0,0,0,10"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Current" Style="{StaticResource LabelHeader}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txt_current_position" Grid.Column="1"
                                           Text="-" FontSize="14" FontWeight="Bold" Foreground="#222"/>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Origin postion" Style="{StaticResource LabelHeader}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txt_origin_pos" Grid.Column="1"
                                           Text="-" FontSize="14" FontWeight="Bold" Foreground="#2563EB"/>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Loaded" Style="{StaticResource LabelHeader}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txt_trongTai" Grid.Column="1"
                                           Text="-" FontSize="14" FontWeight="Bold" Foreground="#2563EB"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- MACHINE LOG -->
                    <Border Grid.Row="4" Style="{StaticResource InfoCard}" Margin="5,0,5,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Machine Log" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#222" Margin="0,0,0,8"/>
                            <ListBox x:Name="list_log"
                                     Grid.Row="1"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="13"
                                     MaxHeight="130"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="White" CornerRadius="8" Padding="10" Margin="0,0,0,6">
                                            <TextBlock Text="{Binding Message}"
                                                       Foreground="{Binding Color}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"/>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- BOTTOM: RESET + FAB -->
                    <Grid Grid.Row="5" Margin="5,0,5,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>

                        <!-- STOP -->
                        <Button x:Name="btn_stop_main"
                                Grid.Column="0"
                                Content="STOP"
                                Click="btn_stop_main_Click"
                                Style="{StaticResource RoundBtn}"
                                Background="#FFF50B4B"
                                Margin="0,0,10,0"/>


                        <!-- RESET -->
                        <Button x:Name="btn_restart"
                                Grid.Column="1"
                                Content="RESET"
                                Click="btn_restart_Click"
                                Style="{StaticResource RoundBtn}"
                                Background="#F59E0B"
                                Margin="0,0,10,0"/>

                        <!-- FAB + POPUP -->
                        <Grid Grid.Column="2" VerticalAlignment="Center">

                            <!-- POPUP JOG PANEL -->
                            <Popup x:Name="popup_jog"
                                   Placement="Left"
                                   PlacementTarget="{Binding ElementName=btn_fab}"
                                   StaysOpen="False"
                                   AllowsTransparency="True"
                                   VerticalOffset="-8">

                                <Border Background="White"
                                        CornerRadius="16"
                                        Padding="16"
                                        Width="230"
                                        Margin="0,0,0,4">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.18"/>
                                    </Border.Effect>

                                    <StackPanel>

                                        <!-- TITLE -->
                                        <TextBlock Text="Điều khiển và lấy gốc"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="#222" Margin="0,0,0,12"/>

                                        <!-- STEP INFO -->
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="khoảng cách/lần" FontSize="12" Foreground="#888" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="txt_step_display"
                                                       Grid.Column="1"
                                                       Text="1000"
                                                       FontSize="14" FontWeight="Bold" Foreground="#4F46E5"/>
                                        </Grid>

                                        <!-- NUMERIC UP DOWN -->
                                        <controls:NumericUpDown
                                            x:Name="num_step"
                                            Value="1000"
                                            Minimum="1"
                                            Maximum="99999"
                                            Interval="100"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="#4F46E5"
                                            Height="38"
                                            BorderThickness="1.5"
                                            Margin="0,0,0,14"
                                            controls:TextBoxHelper.Watermark="Step"
                                            ValueChanged="num_step_ValueChanged"/>

                                        <!-- DIVIDER -->
                                        <Border Height="1" Background="#F0F0F0" Margin="0,0,0,12"/>

                                        <!-- J+ -->
                                        <Button x:Name="btn_start"
                                                Content="▲   J+"
                                                Click="btn_start_Click"
                                                Height="44"
                                                FontSize="16"
                                                FontWeight="SemiBold"
                                                Foreground="White"
                                                Background="#16A34A"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Margin="0,0,0,8">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="10">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="b" Property="Background" Value="#15803D"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="b" Property="Background" Value="#14532D"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <!-- J- -->
                                        <Button x:Name="btn_Stop"
                                                Content="▼   J-"
                                                Click="btn_Stop_Click"
                                                Height="44"
                                                FontSize="16"
                                                FontWeight="SemiBold"
                                                Foreground="White"
                                                Background="#DC2626"
                                                BorderThickness="0"
                                                Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="10">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="b" Property="Background" Value="#B91C1C"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="b" Property="Background" Value="#991B1B"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>


                                        <!-- DIVIDER -->
                                        <Border Height="1" Background="#F0F0F0" Margin="0,10,0,10"/>

                                        <!-- SET ORIGIN -->
                                        <Button x:Name="btn_set_origin"
                                            Content="⌖   Xác định gốc"
                                            Click="btn_set_origin_Click"
                                            Height="44"
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Foreground="White"
                                            Background="#0EA5E9"
                                            BorderThickness="0"
                                            Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="10">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="b" Property="Background" Value="#0284C7"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="b" Property="Background" Value="#0369A1"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </Popup>

                            <!-- FAB BUTTON -->
                            <Button x:Name="btn_fab"
                                    Click="btn_fab_Click"
                                    Width="52"
                                    Height="52"
                                    Cursor="Hand"
                                    ToolTip="Jog Control"
                                    Foreground="White"
                                    Background="#4F46E5"
                                    BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="26">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="b" Property="Background" Value="#4338CA"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="b" Property="Background" Value="#3730A3"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>

                                <!-- Icon: mũi tên lên xuống -->
                                <TextBlock Text="⇅"
                                           FontSize="22"
                                           Foreground="White"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </Button>

                        </Grid>
                    </Grid>

                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>

</controls:MetroWindow>
