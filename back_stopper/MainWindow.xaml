<controls:MetroWindow
    x:Class="back_stopper.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:local="clr-namespace:back_stopper"
    mc:Ignorable="d"
    Title="BackStopper"
    WindowStartupLocation="CenterScreen"
    Background="#F3F6FA"
    MinWidth="1300"
    MinHeight="800"
    Width="1600"
    Height="900"
    Loaded="MetroWindow_Loaded"
    Closed="MetroWindow_Closed" WindowState="Maximized">

    <Window.Resources>

        <!-- BUTTON -->
        <Style x:Key="RoundBtn" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="12,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- INFO CARD -->
        <Style x:Key="InfoCard" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <!-- LABEL HEADER -->
        <Style x:Key="LabelHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <Grid Margin="20">

            <!-- ROOT -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1*" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- ================= LEFT CONTENT (GIỮ NGUYÊN) ================= -->

            <Grid Grid.Column="0"
                  Margin="0,0,20,0">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- EMPLOYEE PANEL -->

                <Border Grid.Row="0"
                        Background="White"
                        CornerRadius="20"
                        Padding="20"
                        Margin="0,0,0,20">

                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15"
                                          ShadowDepth="2"
                                          Opacity="0.15"/>
                    </Border.Effect>

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Employee Login"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="#222"/>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Background="#F5F7FB"
                                CornerRadius="12"
                                Margin="20,0">
                            <TextBox x:Name="txt_id_employee"
                                     Height="45"
                                     FontSize="16"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Padding="15,0"
                                     VerticalContentAlignment="Center"
                                     Foreground="#333"
                                     KeyDown="txt_id_employee_KeyDown"
                                     controls:TextBoxHelper.Watermark="Enter Employee ID"/>
                        </Border>

                        <TextBlock Grid.Column="2"
                                   x:Name="lb_check_emplyee"
                                   Text="None"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   FontSize="22"
                                   FontWeight="SemiBold"/>

                    </Grid>

                </Border>

                <!-- MAIN CARD -->

                <Border Grid.Row="1"
                        x:Name="border_main"
                        Background="White"
                        CornerRadius="20"
                        Padding="30"
                        IsEnabled="False">

                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20"
                                          ShadowDepth="2"
                                          Opacity="0.15"/>
                    </Border.Effect>

                    <StackPanel>

                        <TextBlock Text="BackStopper JSH"
                                   FontSize="30"
                                   FontWeight="SemiBold"
                                   Foreground="#222"
                                   Margin="0,0,0,25"/>

                        <Grid Margin="0,0,0,30">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>

                            <Border Background="#F5F7FB"
                                    CornerRadius="12"
                                    Margin="0,0,15,0">
                                <TextBox x:Name="txt_po"
                                         Height="45"
                                         FontSize="16"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Padding="15,0"
                                         VerticalContentAlignment="Center"
                                         Foreground="#333"
                                         KeyDown="txt_po_KeyDown"
                                         controls:TextBoxHelper.Watermark="Enter PO Product"/>
                            </Border>

                            <Button Grid.Column="1"
                                    x:Name="btn_po_restart"
                                    Click="btn_po_restart_Click"
                                    Content="Restart"
                                    Height="45"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Foreground="White"
                                    Background="#4F46E5"
                                    BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="12">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                        </Grid>

                        <UniformGrid Columns="2" Rows="3">

                            <Border Background="#F8FAFC" CornerRadius="14" Padding="18" Margin="8">
                                <StackPanel>
                                    <TextBlock Text="AUFNR" FontSize="13" Foreground="#777"/>
                                    <TextBlock x:Name="txt_id" FontSize="18" FontWeight="SemiBold" Foreground="#222" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#F8FAFC" CornerRadius="14" Padding="18" Margin="8">
                                <StackPanel>
                                    <TextBlock Text="PSTX" FontSize="13" Foreground="#777"/>
                                    <TextBlock x:Name="txt_PSTX" Text="..." FontSize="18" FontWeight="SemiBold" Foreground="#222" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#F8FAFC" CornerRadius="14" Padding="18" Margin="8">
                                <StackPanel>
                                    <TextBlock Text="GAMNG" FontSize="13" Foreground="#777"/>
                                    <TextBlock x:Name="txt_gamng" Text="..." FontSize="18" FontWeight="SemiBold" Foreground="#222" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#F8FAFC" CornerRadius="14" Padding="18" Margin="8">
                                <StackPanel>
                                    <TextBlock Text="L" FontSize="13" Foreground="#777"/>
                                    <TextBlock x:Name="txt_l" Text="..." FontSize="18" FontWeight="SemiBold" Foreground="#222" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#F8FAFC" CornerRadius="14" Padding="18" Margin="8">
                                <StackPanel>
                                    <TextBlock Text="D" FontSize="13" Foreground="#777"/>
                                    <TextBlock x:Name="txt_d" Text="..." FontSize="18" FontWeight="SemiBold" Foreground="#222" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#F8FAFC" CornerRadius="14" Padding="18" Margin="8">
                                <StackPanel>
                                    <TextBlock Text="AirHole" FontSize="13" Foreground="#777"/>
                                    <TextBlock x:Name="txt_airhole" Text="..." FontSize="18" FontWeight="SemiBold" Foreground="#16A34A" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                        </UniformGrid>

                    </StackPanel>

                </Border>

            </Grid>

            <!-- ================= RIGHT CONTROL (MỚI) ================= -->

            <Border Grid.Column="1"
                    x:Name="border_control"
                    Background="White"
                    CornerRadius="20"
                    Padding="18"
                    IsEnabled="False">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="20"
                                      ShadowDepth="2"
                                      Opacity="0.15"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- HEADER -->
                    <Grid Grid.Row="0" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Machine Control"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#222"
                                   VerticalAlignment="Center"/>

                        <Border Grid.Column="1"
                                Background="#F5F7FB"
                                CornerRadius="8"
                                Margin="10,0,0,0"
                                MinWidth="110">
                            <ComboBox x:Name="cmbPort"
                                      Height="36"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      Padding="8,0"
                                      FontSize="13"
                                      SelectionChanged="cmbPort_SelectionChanged"
                                      VerticalContentAlignment="Center">
                                <ComboBoxItem Content="Disconnect"/>
                            </ComboBox>
                        </Border>
                    </Grid>

                    <!-- SENSORS -->
                    <WrapPanel Grid.Row="1"
                               Orientation="Horizontal"
                               Margin="0,0,0,10">

                        <Border Style="{StaticResource InfoCard}" MinWidth="85">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelHeader}" Text="Sensor Min"/>
                                <TextBlock x:Name="txt_ss1"
                                           Text="OFF"
                                           FontSize="17"
                                           FontWeight="Bold"
                                           Foreground="#DC2626"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource InfoCard}" MinWidth="85">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelHeader}" Text="Sensor Max"/>
                                <TextBlock x:Name="txt_ss2"
                                           Text="OFF"
                                           FontSize="17"
                                           FontWeight="Bold"
                                           Foreground="#DC2626"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource InfoCard}" MinWidth="85">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelHeader}" Text="Sensor Home"/>
                                <TextBlock x:Name="txt_ss3"
                                           Text="OFF"
                                           FontSize="17"
                                           FontWeight="Bold"
                                           Foreground="#DC2626"/>
                            </StackPanel>
                        </Border>

                    </WrapPanel>

                    <!-- SERVO STATUS -->
                    <Border Grid.Row="2"
                            Style="{StaticResource InfoCard}"
                            Margin="5,0,5,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Servo"
                                       Style="{StaticResource LabelHeader}"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="txt_status_servo"
                                       Grid.Column="1"
                                       Text="Please Connect"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="#2563EB"/>
                        </Grid>
                    </Border>

                    <!-- SERVO TRAVEL -->
                    <Border Grid.Row="3"
                            Style="{StaticResource InfoCard}"
                            Margin="5,0,5,10">
                        <StackPanel>

                            <TextBlock Text="Servo Travel"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#222"
                                       Margin="0,0,0,10"/>

                            <!-- Current -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Current"
                                           Style="{StaticResource LabelHeader}"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="txt_current_position"
                                           Grid.Column="1"
                                           Text="0"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="#222"/>
                            </Grid>

                            <!-- Target -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Target"
                                           Style="{StaticResource LabelHeader}"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="txt_target_position"
                                           Grid.Column="1"
                                           Text="0"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="#2563EB"/>
                            </Grid>

                            <!-- Progress -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="45"/>
                                </Grid.ColumnDefinitions>

                                <ProgressBar x:Name="progress_servo"
                                             Height="10"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="0"
                                             Foreground="#4F46E5"
                                             Background="#E5E7EB"
                                             BorderThickness="0"
                                             VerticalAlignment="Center"
                                             Margin="0,0,8,0"/>

                                <TextBlock x:Name="txt_percent"
                                           Grid.Column="1"
                                           Text="0%"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#4F46E5"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"/>
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- MACHINE LOG -->
                    <Border Grid.Row="4"
                            Style="{StaticResource InfoCard}"
                            Margin="5,0,5,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Machine Log"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#222"
                                       Margin="0,0,0,8"/>
                            <!--<ListBox x:Name="list_log"
                                 
                                 MaxHeight="130"

                                 BorderThickness="0"
                                 Background="Transparent"

                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"

                                 HorizontalContentAlignment="Stretch">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="White"
                                                CornerRadius="6"
                                                Padding="8"
                                                Margin="0,0,0,4">
                                            <TextBlock Text="{Binding Message}"
                                                       TextWrapping="Wrap"
                                                       Foreground="#333"/>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>-->


                            <ListBox x:Name="list_log"
                                 Grid.Row="1"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="13"
                                 MaxHeight="130"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>

                                    <DataTemplate>

                                        <Border Background="White"
                                            CornerRadius="8"
                                            Padding="10"
                                            Margin="0,0,0,6">

                                            <TextBlock Text="{Binding Message}"
                                                   Foreground="{Binding Color}"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"/>
                                        </Border>

                                    </DataTemplate>

                                </ListBox.ItemTemplate>

                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- BUTTONS -->
                    <Grid Grid.Row="5" Margin="5,0,5,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="btn_start"
                                Grid.Column="0"
                                Content="J+"
                                Click="btn_start_Click"
                                Style="{StaticResource RoundBtn}"
                                Background="#16A34A"
                                Margin="0,0,5,0"/>

                        <Button x:Name="btn_Stop"
                                Grid.Column="1"
                                Content="J-"
                                Click="btn_Stop_Click"
                                Style="{StaticResource RoundBtn}"
                                Background="#DC2626"
                                Margin="3,0"/>

                        <Button x:Name="btn_restart"
                                Grid.Column="2"
                                Content="RESET"
                                Click="btn_restart_Click"
                                Style="{StaticResource RoundBtn}"
                                Background="#F59E0B"
                                Margin="5,0,0,0"/>
                    </Grid>

                </Grid>
            </Border>

        </Grid>

    </ScrollViewer>

</controls:MetroWindow>
