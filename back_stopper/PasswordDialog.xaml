<controls:MetroWindow
    x:Class="back_stopper.PasswordDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
    WindowStartupLocation="CenterOwner"
    ShowTitleBar="False"
    ShowCloseButton="False"
    ResizeMode="NoResize"
    Width="380"
    SizeToContent="Height"
    Background="Transparent"
    AllowsTransparency="True"
    WindowStyle="None"
    GlowBrush="Transparent">

    <Border Background="White"
            CornerRadius="20"
            Padding="28,24">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="4" Opacity="0.2"/>
        </Border.Effect>

        <StackPanel>

            <!-- ICON + TITLE -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">

                <Border Width="44" Height="44" CornerRadius="22"
                        Background="#EEF2FF" VerticalAlignment="Center"
                        Margin="0,0,14,0">
                    <TextBlock Text="🔒" FontSize="20"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Xác thực"
                               FontSize="18" FontWeight="SemiBold" Foreground="#111"/>
                    <TextBlock Text="Nhập mật khẩu để mở Jog Control"
                               FontSize="12" Foreground="#888" Margin="0,2,0,0"/>
                </StackPanel>

            </StackPanel>

            <!-- DIVIDER -->
            <Border Height="1" Background="#F0F0F0" Margin="0,0,0,20"/>

            <!-- PASSWORD INPUT -->
            <TextBlock Text="Mật khẩu"
                       FontSize="12" Foreground="#888" Margin="0,0,0,6"/>

            <Border x:Name="border_input"
                    Background="#F5F7FB"
                    CornerRadius="10"
                    BorderThickness="1.5"
                    BorderBrush="Transparent"
                    Margin="0,0,0,6">
                <PasswordBox x:Name="txt_password"
                             Height="42"
                             FontSize="15"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="14,0"
                             VerticalContentAlignment="Center"
                             Foreground="#333"
                             KeyDown="txt_password_KeyDown"/>
            </Border>

            <!-- ERROR MESSAGE -->
            <TextBlock x:Name="txt_error"
                       Text="Mật khẩu không đúng!"
                       FontSize="12"
                       Foreground="#DC2626"
                       FontWeight="SemiBold"
                       Margin="0,0,0,16"
                       Visibility="Collapsed"/>

            <!-- BUTTONS -->
            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- HỦY -->
                <Button x:Name="btn_cancel"
                        Grid.Column="0"
                        Content="Hủy"
                        Height="42"
                        FontSize="14" FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="btn_cancel_Click"
                        Foreground="#555"
                        Background="#F3F4F6"
                        BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="#E5E7EB"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- XÁC NHẬN -->
                <Button x:Name="btn_confirm"
                        Grid.Column="2"
                        Content="Xác nhận"
                        Height="42"
                        FontSize="14" FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="btn_confirm_Click"
                        Foreground="White"
                        Background="#4F46E5"
                        BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="#4338CA"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </Grid>

        </StackPanel>
    </Border>

</controls:MetroWindow>
