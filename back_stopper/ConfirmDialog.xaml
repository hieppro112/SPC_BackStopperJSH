<controls:MetroWindow
    x:Class="back_stopper.ConfirmDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
    WindowStartupLocation="CenterOwner"
    ShowTitleBar="False"
    ShowCloseButton="False"
    ResizeMode="NoResize"
    Width="420"
    Height="Auto"
    SizeToContent="Height"
    Background="Transparent"
    AllowsTransparency="True"
    WindowStyle="None"
    GlowBrush="Transparent">

    <Border Background="White"
            CornerRadius="20"
            Padding="32,28">

        <Border.Effect>
            <DropShadowEffect BlurRadius="30"
                              ShadowDepth="4"
                              Opacity="0.2"/>
        </Border.Effect>

        <StackPanel>

            <!-- ICON + TITLE -->
            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,16">

                <!-- Icon vòng tròn màu -->
                <Border x:Name="iconBorder"
                        Width="44"
                        Height="44"
                        CornerRadius="22"
                        Background="#EEF2FF"
                        VerticalAlignment="Center"
                        Margin="0,0,14,0">
                    <TextBlock x:Name="iconText"
                               Text="?"
                               FontSize="22"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#4F46E5"/>
                </Border>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="txt_title"
                               Text="Xác nhận"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#111"/>
                    <TextBlock x:Name="txt_subtitle"
                               Text="Hành động này cần xác nhận"
                               FontSize="12"
                               Foreground="#888"
                               Margin="0,2,0,0"/>
                </StackPanel>

            </StackPanel>

            <!-- DIVIDER -->
            <Border Height="1"
                    Background="#F0F0F0"
                    Margin="0,0,0,20"/>

            <!-- MESSAGE -->
            <TextBlock x:Name="txt_message"
                       Text="Bạn có chắc chắn muốn thực hiện?"
                       FontSize="15"
                       Foreground="#333"
                       TextWrapping="Wrap"
                       LineHeight="24"
                       Margin="0,0,0,28"/>

            <!-- BUTTONS -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- HỦY -->
                <Button x:Name="btn_cancel"
                        Grid.Column="0"
                        Content="Hủy"
                        Height="42"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="btn_cancel_Click"
                        Foreground="#555"
                        Background="#F3F4F6"
                        BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="btnBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="btnBorder" Property="Background" Value="#E5E7EB"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- XÁC NHẬN -->
                <Button x:Name="btn_confirm"
                        Grid.Column="2"
                        Content="Xác nhận"
                        Height="42"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="btn_confirm_Click"
                        Foreground="White"
                        Background="#4F46E5"
                        BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="btnBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="btnBorder" Property="Background" Value="#4338CA"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </Grid>

        </StackPanel>
    </Border>

</controls:MetroWindow>
